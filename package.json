{
  "name": "smart-harbor",
  "version": "1.2.4",
  "type": "module",
  "scripts": {
    "dev:client": "vite",
    "dev:server": "NODE_ENV=development PORT=3001 CONFIG_DIR=./config tsx watch server/index.ts",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "build:client": "tsc && vite build",
    "build:extension": "tsc -p extension/tsconfig.json --noEmit && vite build --config extension/vite.config.ts && node extension/scripts/write-manifest.mjs",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "package:extension": "node extension/scripts/package-extension.mjs",
    "preview": "NODE_ENV=production PORT=3001 CONFIG_DIR=./config node dist-server/server/index.js",
    "start": "NODE_ENV=production PORT=80 CONFIG_DIR=/app/config node dist-server/server/index.js",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 1",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"server/**/*.ts\""
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.62.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify": "^5.8.2",
    "globals": "^17.4.0",
    "lucide-react": "^0.468.0",
    "pinyin-pro": "^3.27.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.3",
    "tailwind-merge": "^3.5.0",
    "typescript-eslint": "^8.56.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
